# Almost Surely Profitable - Example Configuration
# Copy this file to `.env` and fill in your own values.
# IMPORTANT: `.env` is in `.gitignore` and should never be committed.

# LLM API Configuration
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=kimi
LLM_API_KEY=your-api-key-here

# Optional: LLM request timeout in seconds (default: 180)
LLM_TIMEOUT=180

# Optional: retry behavior for transient LLM API failures
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_FACTOR=1.0

# Optional: HTTP User-Agent header sent with LLM requests
LLM_USER_AGENT=python-trading-agent/1.0

# Optional: sampling temperature for LLM decisions (default: 0.3)
LLM_TEMPERATURE=0.3

# Trading Parameters
INITIAL_CAPITAL=10000
CURRENCY=EUR

# Risk Management
MAX_POSITION_PCT=25
MAX_DAILY_LOSS_PCT=3
STOP_LOSS_PCT=5

# Data Configuration
DATA_CACHE_DAYS=30
